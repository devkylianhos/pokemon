# Kopieer naar .env en vul in voor de always-on tracker (VPS/Docker).
# NIET committen — .env staat in .gitignore.

# Supabase (Project Settings > API)
SUPABASE_URL=https://JOUWPROJECT.supabase.co
SUPABASE_SERVICE_KEY=je-service-role-key

# bol Retailer API (developers.bol.com)
BOL_CLIENT_ID=je-client-id
BOL_CLIENT_SECRET=je-client-secret

# Discord-webhook voor alerts (Serverinstellingen > Integraties > Webhooks)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy

# Poll-interval in seconden (60 = elke minuut)
INTERVAL=60
